#!/usr/bin/env bash

# Shows task descriptions from the favourite commands task file in fzf, lets the user pick one,
# extracts the selected task's name, and then runs `task ... {task-name}` to execute it.
#
# Dependencies:
# - task >= 3.48: https://github.com/go-task/task
# - jq: https://github.com/jqlang/jq

set -euo pipefail

TASKFILE="${HOME}/.local/bin/data/task/favourite-commands.yml"
TASK_DIR="."

name="$(
  task --taskfile "$TASKFILE" --dir="$TASK_DIR" --list --json \
    | jq -r '.tasks[] | [.desc, (@base64)] | @tsv' \
    | fzf --no-preview --delimiter=$'\t' --with-nth=1 \
    | cut -f2 \
    | base64 --decode \
    | jq -r '.name'
)"

task --interactive --taskfile "$TASKFILE" --dir="$TASK_DIR" "$name"
