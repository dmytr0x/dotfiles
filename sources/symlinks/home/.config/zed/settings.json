{
  // ==================== cli ====================
  "cli_default_open_behavior": "new_window",

  // ==================== UI & Appearance ====================
  "outline_panel": {
    "dock": "right",
  },
  "theme": {
    "mode": "system",
    "light": "Dmytr0x Light Modern",
    "dark": "Dmytr0x Dark Modern",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  //
  "scrollbar": {
    "show": "never",
  },
  // Markdown
  "markdown_preview_font_family": "FiraCode Nerd Font",
  "markdown_preview_theme": "Dmytr0x Dark Modern",

  // ==================== Fonts ====================
  "ui_font_family": ".ZedMono",
  "ui_font_size": 14.0,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 12.5,
  "buffer_font_weight": 300,
  "buffer_line_height": { "custom": 1.4 },
  "buffer_font_features": {
    "calt": false,
  },
  "git_commit_buffer_font_size": 12.5,

  // ==================== Editor ====================
  "preferred_line_length": 100,
  "current_line_highlight": "none",
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
  },
  "completion_menu_item_kind": "symbol",

  // ==================== Language-specific ====================
  "languages": {
    "Python": {
      "indent_guides": { "enabled": false },
      // details:
      //
      // basedpyright - https://zed.dev/docs/languages/python#basedpyright
      // ty           - https://docs.astral.sh/ty/editors/#zed
      //
      "language_servers": ["ty", "ruff", "!basedpyright"],
      // INFO: that will disable the built-in debug configurations
      //       only the .zed/debug.json will be used
      "debuggers": ["debugpy"],
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "formatter": "language_server",
    },
    "JSON": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
    "JSONC": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
    "YAML": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
    "TOML": {
      "tab_size": 2,
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
      "formatter": {
        "external": {
          "command": "taplo",
          "arguments": ["fmt", "-"],
        },
      },
      "format_on_save": "off",
    },
  },

  // ========Language Server Protocol ==============
  // Whether to automatically show a signature help pop-up or not.
  // To show it manually, press: `cmd+i` (editor::ShowSignatureHelp)
  "auto_signature_help": false,
  "go_to_definition_scroll_strategy": "center",
  "go_to_definition_fallback": "none",
  // Add LSP document symbols to the breadcrumbs and outline UI
  "document_symbols": "on",
  //
  "lsp": {
    // details:
    // - https://docs.astral.sh/ty/reference/editor-settings
    // - https://docs.astral.sh/ty/reference/configuration/
    "ty": {
      "settings": {
        "diagnosticMode": "openFilesOnly",
      },
    },
    // details: https://docs.basedpyright.com/latest/configuration/language-server-settings/
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
        },
        "basedpyright.analysis": {
          "diagnosticMode": "openFilesOnly", // "openFilesOnly" | "workspace"
          "typeCheckingMode": "recommended", // "off" | "basic" | "standard" | "strict" | "recommended" | "all"
          "inlayHints": {
            "variableTypes": true,
            "functionReturnTypes": true,
            "genericTypes": true,
            "callArgumentNames": true,
            "callArgumentNamesMatching": true,
          },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": { "command": "clippy" },
      },
    },
  },

  // ==================== Panels ====================
  "project_panel": {
    "dock": "right",
    "diagnostic_badges": false,
    "entry_spacing": "standard",
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "pane_split_direction_vertical": "left",
  "pane_split_direction_horizontal": "up",

  // ==================== Git ====================
  "git": {
    "worktree_directory": "../.worktrees",
    "hunk_style": "unstaged_hollow",
    "inline_blame": {
      "show_commit_summary": true,
      "enabled": true,
      "delay_ms": 5000,
    },
  },
  "git_panel": {
    "dock": "right",
    "scrollbar": { "show": "never" },
    "tree_view": true,
    "sort_by_path": true,
    "show_count_badge": true,
    "file_icons": true,
  },

  // ==================== Tabs & Toolbar ====================
  "tab_bar": {
    "show": true,
    "show_pinned_tabs_in_separate_row": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": false,
    "show_diagnostics": "errors",
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },

  // ==================== Terminal ====================
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "font_weight": 300,
    "font_size": 12,
    "cursor_shape": "bar",
    "copy_on_select": true,
    "blinking": "on",
    // Use Zed as the default editor for the built-in terminal
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
    //
    // "path_hyperlink_regexes": [...]
    // "scroll_multiplier": 0
  },
  "load_direnv": "shell_hook",

  // ==================== Search ====================
  "search": {
    "center_on_match": true,
    "button": false,
  },
  "seed_search_query_from_cursor": "selection",

  // ==================== AI & Agent ====================
  // Completely disable or enable all AI features in the editor
  // You can enable or disable AI on a per-project basis
  "disable_ai": true,
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secret*.yml",
    "**/secret*.yaml",
  ],

  // ==================== Auto completions ====================
  "completions": {
    "words": "fallback",
    "words_min_length": 3,
    "lsp": true,
    "lsp_fetch_timeout_ms": 0,
    "lsp_insert_mode": "replace_suffix",
  },

  // ==================== Behavior ====================
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false,
  },

  // ==================== Files & Projects ====================
  "file_scan_exclusions": [".ruff_cache", ".mypy_cache", "**/__pycache__", "**/.pytest_cache"],

  // ==================== Keymap ====================
  "base_keymap": "VSCode",

  // ==================== Profiles ====================
  "profiles": {
    "Compact": {
      "settings": {
        "theme": "Dmytr0x Dark Modern",
        "icon_theme": "Catppuccin Mocha",
        "buffer_font_size": 10,
        "ui_font_size": 12,
      },
    },
    "Zen": {
      "settings": {
        "theme": "Dmytr0x Dark Modern",
        "icon_theme": "Catppuccin Mocha",
        "buffer_font_size": 16,
        "agent_buffer_font_size": 15.0,
        "ui_font_size": 15.0,
        "tab_bar": {
          "show": false,
        },
        "toolbar": {
          "breadcrumbs": false,
        },
        "status_bar": {
          "experimental.show": false,
        },
        "title_bar": {
          "show_branch_name": false,
        },
        "gutter": {
          "line_numbers": false,
        },
        "indent_guides": {
          "enabled": false,
        },
      },
    },
    "Presentation": {
      "settings": {
        "theme": "Dmytr0x Dark Modern",
        "icon_theme": "Catppuccin Mocha",
        "buffer_font_size": 20,
        "ui_font_size": 18,
      },
    },
  },

  // ==================== Extensions ====================
  "auto_install_extensions": {
    "opencode": true,
    "codex-acp": true,
    "vscode-dark-modern": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "proto": true,
    "terraform": true,
    "lua": true,
    "html": true,
    "toml": true,
    "bash": true,
    "sql": true,
  },

  // ==================== System ====================
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
