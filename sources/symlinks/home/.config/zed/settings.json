{
  // ==================== UI & Appearance ====================
  "theme": "VSCode Dark Modern",
  "icon_theme": "Catppuccin Mocha",
  "theme_overrides": {
    "VSCode Dark Modern": {
      "syntax": {
        "comment": { "color": "#3d6832" },
        "hint": { "color": "#454545" },
        "variable.parameter": { "color": "#F7768E" },
      },
      "tab.active_background": "#423e36",
      "editor.background": "#181818",
      "editor.gutter.background": "#181818",
      "terminal.background": "#181818",
      "panel.background": "#1f1f1f",
    },
  },
  "scrollbar": {
    "show": "never",
  },

  // ==================== Fonts ====================
  "ui_font_family": ".ZedMono",
  "ui_font_size": 14.0,
  "buffer_font_family": ".ZedMono",
  "buffer_font_size": 13.0,
  "buffer_line_height": { "custom": 1.4 },
  "buffer_font_features": {
    "calt": false,
  },

  // ==================== Editor ====================
  "preferred_line_length": 100,
  "current_line_highlight": "none",
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
  },

  // ==================== Language-specific ====================
  "languages": {
    "Python": {
      "indent_guides": { "enabled": false },
      // details:
      //
      // basedpyright - https://zed.dev/docs/languages/python#basedpyright
      // ty           - https://docs.astral.sh/ty/editors/#zed
      //
      "language_servers": ["basedpyright", "ruff", "!ty"],
      // INFO: that will disable the built-in debug configurations
      //       only the .zed/debug.json will be used
      "debuggers": ["debugpy"],
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "formatter": "language_server",
    },
    "JSON": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
    "JSONC": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
    "YAML": {
      "indent_guides": { "enabled": true, "coloring": "indent_aware" },
    },
  },

  // ========Language Server Protocol ==============
  // Whether to automatically show a signature help pop-up or not.
  // To show it manually, press: `cmd+i` (editor::ShowSignatureHelp)
  "auto_signature_help": false,
  "go_to_definition_fallback": "none",
  // Add LSP document symbols to the breadcrumbs and outline UI
  "document_symbols": "on",
  //
  "lsp": {
    // details: https://docs.basedpyright.com/latest/configuration/language-server-settings/
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
        },
        "basedpyright.analysis": {
          "diagnosticMode": "openFilesOnly", // "openFilesOnly" | "workspace"
          "typeCheckingMode": "recommended", // "off" | "basic" | "standard" | "strict" | "recommended" | "all"
          "inlayHints": {
            "variableTypes": true,
            "functionReturnTypes": true,
            "genericTypes": true,
            "callArgumentNames": true,
            "callArgumentNamesMatching": true,
          },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": { "command": "clippy" },
      },
    },
  },

  // ==================== Panels ====================
  "project_panel": {
    "diagnostic_badges": false,
    "entry_spacing": "standard",
  },
  "collaboration_panel": {
    "button": false,
  },
  "pane_split_direction_vertical": "left",
  "pane_split_direction_horizontal": "up",

  // ==================== Git ====================
  "git": {
    "hunk_style": "unstaged_hollow",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 5000,
    },
  },
  "git_panel": {
    "dock": "right",
    "scrollbar": { "show": "never" },
    "tree_view": true,
    "sort_by_path": true,
  },

  // ==================== Tabs & Toolbar ====================
  "tab_bar": {
    "show": true,
    "show_pinned_tabs_in_separate_row": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": false,
    "show_diagnostics": "errors",
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": true,
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },

  // ==================== Terminal ====================
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "font_size": 12,
    "cursor_shape": "bar",
    "copy_on_select": true,
    "blinking": "on",
    // Use Zed as the default editor for the built-in terminal
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
    //
    // "path_hyperlink_regexes": [...]
    // "scroll_multiplier": 0
  },
  "load_direnv": "shell_hook",

  // ==================== Search ====================
  "search": {
    "center_on_match": true,
    "button": false,
  },
  "seed_search_query_from_cursor": "selection",

  // ==================== AI & Agent ====================
  // Completely disable or enable all AI features in the editor
  // You can enable or disable AI on a per-project basis
  "disable_ai": false,
  //
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "default_model": "openai/gpt-5.3-codex/high",
      "default_mode": "build",
      "favorite_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex/high",
        "openai/gpt-5.3-codex/medium",
        "openai/gpt-5.3-codex/low",
        "github-copilot/claude-opus-4.6",
      ],
    },
  },
  "agent": {
    "enable_feedback": false,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
  },
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secret*.yml",
    "**/secret*.yaml",
  ],
  // On/off edit predictions
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle", // Display predictions inline only when holding a modifier key (alt by default)
    // INFO: The `copilot` is using more than 1GB of memory
    "provider": "zed",
    "disabled_globs": ["**/.env", "**/.env.*", "**/.env-*", "**/.env_*"],
  },
  // Auto completions
  "completions": {
    "words": "fallback",
    "words_min_length": 3,
    "lsp": true,
    "lsp_fetch_timeout_ms": 0,
    "lsp_insert_mode": "replace_suffix",
  },
  "language_models": {
    "openai_compatible": {
      "zai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-4.7",
            "display_name": "GLM-4.7",
            "max_tokens": 204800,
            "max_output_tokens": 98304,
            "max_completion_tokens": 204800,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },

  // ==================== Behavior ====================
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false,
  },

  // ==================== Files & Projects ====================
  "file_scan_exclusions": [".ruff_cache", ".mypy_cache", "**/__pycache__", "**/.pytest_cache"],

  // ==================== Keymap ====================
  "base_keymap": "VSCode",

  // ==================== Profiles ====================
  "profiles": {
    "Zen": {
      // "theme": "VSCode Dark Modern",
      "buffer_font_size": 16,
      "agent_buffer_font_size": 15.0,
      "ui_font_size": 15.0,
      "tab_bar": { "show": false },
      "toolbar": { "breadcrumbs": false },
      "status_bar": { "experimental.show": false },
      "title_bar": {
        "show_branch_icon": false,
        "show_branch_name": false,
      },
      "gutter": { "line_numbers": false },
      "indent_guides": { "enabled": false },
    },
    "Presentation": {
      "theme": "VSCode Dark Modern",
      "buffer_font_size": 20,
      "ui_font_size": 18,
    },
  },

  // ==================== Extensions ====================
  "auto_install_extensions": {
    "vscode-dark-modern": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "terraform": true,
    "toml": true,
    "bash": true,
    "sql": true,
  },

  // ==================== System ====================
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
