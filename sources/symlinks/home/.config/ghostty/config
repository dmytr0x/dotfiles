#
# 👻 Info: https://ghostty.org/docs/config/reference
#

auto-update = off

# Look and feel:
font-family = Fira Code
macos-titlebar-style = tabs
window-decoration = true
window-colorspace = display-p3
background = #000000
background-opacity = 0.95
background-blur-radius = 20

# Mouse:
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3

# Typing:
macos-option-as-alt = true
copy-on-select = clipboard

# Shell
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Splits:
split-divider-color = #007CD2
unfocused-split-opacity = 0.4

# Terminal:
quick-terminal-animation-duration = 0

# Key bindings:
keybind = global:ctrl+alt+cmd+/=toggle_quick_terminal
# keybind = shift+enter=text:\n
#
# Adjust the pane size
#
# keybind = resize/arrow_up=resize_split:up,10
# keybind = resize/arrow_down=resize_split:down,10
# keybind = resize/arrow_left=resize_split:left,10
# keybind = resize/arrow_right=resize_split:right,10
# keybind = resize/escape=deactivate_key_table
# keybind = resize/catch_all=ignore
# keybind = ctrl+a=activate_key_table:resize
# Toggle full screen for the active pane
keybind = cmd+shift+enter=unbind
keybind = shift+escape=toggle_split_zoom
#
