#!/usr/bin/env bash

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_SUPPORT_DIR="${HOME}/Library/Application Support"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Find source files of a given type.
#   list_sources <subdirectory> <glob pattern>
list_sources() {
  find "${DOTFILES_DIR}/sources/$1" -type f -name "$2" | sort
}

# Strip the DOTFILES_DIR prefix for user-facing output.
display_path() {
  echo "${1#"${DOTFILES_DIR}/"}"
}

# Prompt the user with a yes/no question.
# Returns exit code 0 for yes, 1 for no.
#   yes_no_question <prompt> [default: y]
yes_no_question() {
  local prompt="$1"
  local default="${2:-y}"
  local options=$([[ "$default" == "y" ]] && echo "Y/n" || echo "y/N")
  local answer

  while true; do
    if [[ -r /dev/tty ]]; then
      read -r -p "$prompt [$options]: " answer </dev/tty
    else
      read -r -p "$prompt [$options]: " answer
    fi

    case "$answer" in
      [Yy]|[Yy][Ee][Ss]) return 0 ;;
      [Nn]|[Nn][Oo])    return 1 ;;
      "")    [[ "$default" == "y" ]] && return 0 || return 1 ;;
      *)     printf 'Please answer with yes or no.\n' >&2 ;;
    esac
  done
}

# Print a section header with optional subtitle.
print_header() {
  echo "------------------------------------------"
  [[ -n "${1:-}" ]] && echo "$1"
}

# ---------------------------------------------------------------------------
# Symlinks
# ---------------------------------------------------------------------------

sync_symlinks() {
  local extra_flags=()
  [[ "$1" == "uninstall" ]] && extra_flags=(--delete)

  stow --dir="${DOTFILES_DIR}/sources/symlinks" --target="${HOME}" --verbose "${extra_flags[@]}" home
  stow --dir="${DOTFILES_DIR}/sources/symlinks" --target="${APP_SUPPORT_DIR}" --verbose "${extra_flags[@]}" application_support
}

install_symlinks() {
  # Atuin constantly checks its configuration and creates it if it doesn't exist.
  # We need to clean it up before creating the symlink.
  local atuin_config="${HOME}/.config/atuin/config.toml"
  if [[ -f "$atuin_config" ]]; then
    mv -f "$atuin_config" "${atuin_config}.back"
  fi

  # To keep the Git working directory clean, we link specific files rather
  # than the entire folder. Ensure the base folder exists first.
  mkdir -p "${APP_SUPPORT_DIR}/Code/User"

  sync_symlinks "install"
}

# ---------------------------------------------------------------------------
# Brewfiles
# ---------------------------------------------------------------------------

show_brewfile() {
  print_header "${2:-}"
  grep -vE '^(#|$)' "$1"
  echo
}

install_brewfile() {
  show_brewfile "$1"

  if yes_no_question "Do you want to install $(display_path "$1")?"; then
    brew bundle --no-upgrade --file="$1"
  fi
}

uninstall_brew_packages_by_type() {
  local file="$1"
  local type_flag="--$2"
  local package

  while IFS= read -r package; do
    if [[ -n "$package" ]] && brew list "$type_flag" "$package" &>/dev/null; then
      brew uninstall "$type_flag" "$package"
    fi
  done < <(brew bundle list "$type_flag" --file="$file")
}

uninstall_brewfile() {
  show_brewfile "$1" "Uninstalling dependencies from $(display_path "$1")"
  uninstall_brew_packages_by_type "$1" "formula"
  uninstall_brew_packages_by_type "$1" "cask"
}

install_brewfiles() {
  while IFS= read -r file; do
    install_brewfile "$file"
  done < <(list_sources "brewfiles" "*.Brewfile")
}

uninstall_brewfiles() {
  while IFS= read -r file; do
    uninstall_brewfile "$file"
  done < <(list_sources "brewfiles" "*.Brewfile")
}

# ---------------------------------------------------------------------------
# Scripts
# ---------------------------------------------------------------------------

install_script() {
  print_header "Install script: $(display_path "$1")"
  echo

  if yes_no_question "Do you want to run $(display_path "$1")?"; then
    bash "$1"
  fi
}

install_scripts() {
  while IFS= read -r file; do
    install_script "$file"
  done < <(list_sources "scripts" "*.sh")
}

# ---------------------------------------------------------------------------
# Top-level actions
# ---------------------------------------------------------------------------

install_dotfiles() {
  if yes_no_question "Do you want to install symlinked dotfiles?"; then
    install_symlinks
  fi

  install_brewfiles
  install_scripts
}

uninstall_dotfiles() {
  if yes_no_question "Do you want to uninstall symlinked dotfiles?"; then
    sync_symlinks "uninstall"
  fi

  if yes_no_question "Do you want to uninstall Homebrew packages from all Brewfiles?" "n"; then
    uninstall_brewfiles
  fi
}

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

usage() {
  local name
  name="$(basename "$0")"

  cat <<EOF
Usage:
  ${name} <install|uninstall>
  ${name} <install|uninstall> <symlinks|brewfiles|scripts>

Examples:
  ${name} install symlinks
  ${name} uninstall symlinks
  ${name} install brewfiles
  ${name} uninstall brewfiles
  ${name} install scripts
EOF
}

if [[ "$#" -gt 2 ]]; then
  usage
  exit 1
fi

# Accept both singular and plural forms (e.g. "symlink" and "symlinks").
action="${1:-}"
target="${2:-all}"
target="${target%s}"

case "${action}:${target}" in
  install:all)       install_dotfiles ;;
  uninstall:all)     uninstall_dotfiles ;;
  install:symlink)
    if yes_no_question "Do you want to install symlinks?"; then
      install_symlinks
    fi
    ;;
  uninstall:symlink) sync_symlinks "uninstall" ;;
  install:brewfile)  install_brewfiles ;;
  uninstall:brewfile) uninstall_brewfiles ;;
  install:script)    install_scripts ;;
  uninstall:script)
    printf 'Scripts support only the install action.\n' >&2
    exit 1
    ;;
  *)
    usage
    exit 1
    ;;
esac
